{
  "info": {
    "name": "Shopify Dashboard API",
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f23456789012",
    "description": "All NestJS endpoints exposed by apps/api. Auth via JWT bearer. Login first → token auto-stored in {{access_token}}. Refresh via httpOnly cookie.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "user_email", "value": "" },
    { "key": "user_role", "value": "" },
    { "key": "user_perms", "value": "" },
    { "key": "admin_email", "value": "admin@example.com" },
    { "key": "admin_password", "value": "Admin@12345" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  if (r.accessToken) {",
              "    pm.collectionVariables.set('access_token', r.accessToken);",
              "    pm.environment.set('access_token', r.accessToken);",
              "    console.log('✓ access_token saved');",
              "  }",
              "  if (r.user) {",
              "    pm.collectionVariables.set('user_id', r.user.id);",
              "    pm.collectionVariables.set('user_email', r.user.email);",
              "    pm.collectionVariables.set('user_role', r.user.role);",
              "    if (Array.isArray(r.user.permissions)) {",
              "      pm.collectionVariables.set('user_perms', r.user.permissions.join(','));",
              "    }",
              "    console.log('✓ user:', r.user.email, '(' + r.user.role + ')');",
              "  }",
              "  const setCookie = pm.response.headers.get('Set-Cookie');",
              "  if (setCookie) {",
              "    const m = /refresh_token=([^;]+)/.exec(setCookie);",
              "    if (m) {",
              "      const raw = decodeURIComponent(m[1]);",
              "      pm.collectionVariables.set('refresh_token', raw);",
              "      pm.environment.set('refresh_token', raw);",
              "      console.log('✓ refresh_token saved');",
              "    }",
              "  }",
              "  pm.test('Login 2xx', () => pm.response.to.be.success);",
              "  pm.test('Has accessToken', () => pm.expect(r.accessToken).to.be.a('string'));",
              "} else {",
              "  pm.test('Login failed', () => pm.expect.fail(r.message || 'unknown'));",
              "}"
            ], "type": "text/javascript" }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            }
          }
        },
        {
          "name": "Refresh (uses httpOnly cookie)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  if (r.accessToken) {",
              "    pm.collectionVariables.set('access_token', r.accessToken);",
              "    pm.environment.set('access_token', r.accessToken);",
              "    console.log('✓ access_token rotated');",
              "  }",
              "  const setCookie = pm.response.headers.get('Set-Cookie');",
              "  if (setCookie) {",
              "    const m = /refresh_token=([^;]+)/.exec(setCookie);",
              "    if (m) {",
              "      const raw = decodeURIComponent(m[1]);",
              "      pm.collectionVariables.set('refresh_token', raw);",
              "      pm.environment.set('refresh_token', raw);",
              "      console.log('✓ refresh_token rotated');",
              "    }",
              "  }",
              "  pm.test('Refresh ok', () => pm.response.to.be.success);",
              "}"
            ], "type": "text/javascript" }
          }],
          "request": { "method": "POST", "url": "{{base_url}}/auth/refresh" }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{base_url}}/auth/logout" }
        },
        {
          "name": "Me",
          "request": { "method": "GET", "url": "{{base_url}}/auth/me" }
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        { "name": "List users", "request": { "method": "GET", "url": "{{base_url}}/users" } },
