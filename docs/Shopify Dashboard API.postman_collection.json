          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager@example.com\",\n  \"password\": \"Manager@12345\",\n  \"firstName\": \"Mark\",\n  \"lastName\": \"Manager\",\n  \"roleId\": \"<get-from-GET /roles>\"\n}" }
          }
        },
        {
          "name": "Assign role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users/<user-id>/role",
            "body": { "mode": "raw", "raw": "{\n  \"roleId\": \"<role-uuid>\"\n}" }
          }
        },
        {
          "name": "Set active",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
