{
  "info": {
    "name": "Shopify Dashboard API",
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f23456789012",
    "description": "All NestJS endpoints exposed by apps/api. Auth via JWT bearer. Login first → token auto-stored in {{access_token}}. Refresh via httpOnly cookie.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api" },
    { "key": "access_token", "value": "" },
    { "key": "admin_email", "value": "admin@example.com" },
    { "key": "admin_password", "value": "Admin@12345" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.accessToken) { pm.collectionVariables.set('access_token', r.accessToken); }"
            ], "type": "text/javascript" }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            }
          }
        },
        {
          "name": "Refresh (uses httpOnly cookie)",
          "request": { "method": "POST", "url": "{{base_url}}/auth/refresh" }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{base_url}}/auth/logout" }
        },
        {
          "name": "Me",
          "request": { "method": "GET", "url": "{{base_url}}/auth/me" }
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        { "name": "List users", "request": { "method": "GET", "url": "{{base_url}}/users" } },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager@example.com\",\n  \"password\": \"Manager@12345\",\n  \"firstName\": \"Mark\",\n  \"lastName\": \"Manager\",\n  \"roleId\": \"<role-uuid>\"\n}" }
          }
        },
        {
          "name": "Assign role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users/<user-id>/role",
            "body": { "mode": "raw", "raw": "{\n  \"roleId\": \"<role-uuid>\"\n}" }
          }
        },
        {
          "name": "Set active",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users/<user-id>/active",
            "body": { "mode": "raw", "raw": "{\n  \"isActive\": false\n}" }
          }
        }
      ]
    },
    {
      "name": "3. Catalog - Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?take=25&skip=0",
              "host": ["{{base_url}}"], "path": ["products"],
              "query": [
                { "key": "take", "value": "25" },
                { "key": "skip", "value": "0" },
                { "key": "q", "value": "", "disabled": true },
                { "key": "status", "value": "ACTIVE", "disabled": true }
              ]
            }
          }
        },
        { "name": "Get product", "request": { "method": "GET", "url": "{{base_url}}/products/<product-id>" } },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/products",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Sample T-Shirt\",\n  \"description\": \"100% cotton\",\n  \"productType\": \"Apparel\",\n  \"vendor\": \"Acme\",\n  \"tags\": [\"new\", \"summer\"],\n  \"status\": \"DRAFT\"\n}" }
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/products/gid://shopify/Product/12345",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated title\",\n  \"status\": \"ACTIVE\"\n}" }
          }
        },
        {
          "name": "Delete product",
          "request": { "method": "DELETE", "url": "{{base_url}}/products/gid://shopify/Product/12345" }
        }
      ]
    },
    {
      "name": "4. Catalog - Collections",
      "item": [
        { "name": "List collections", "request": { "method": "GET", "url": "{{base_url}}/collections" } },
        { "name": "Get collection", "request": { "method": "GET", "url": "{{base_url}}/collections/<collection-id>" } }
      ]
    },
    {
      "name": "5. Inventory",
      "item": [
        {
          "name": "Levels",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/inventory/levels",
              "host": ["{{base_url}}"], "path": ["inventory", "levels"],
              "query": [{ "key": "locationId", "value": "", "disabled": true }]
            }
          }
        },
        {
          "name": "Adjust inventory",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/inventory/adjust",
            "body": { "mode": "raw", "raw": "{\n  \"inventoryItemId\": \"42424242\",\n  \"locationId\": \"<location-id>\",\n  \"delta\": 50,\n  \"reason\": \"correction\",\n  \"reference\": \"manual-001\"\n}" }
          }
        },
        { "name": "Stock alerts", "request": { "method": "GET", "url": "{{base_url}}/inventory/alerts" } }
      ]
    },
    {
      "name": "6. Orders",
      "item": [
        {
          "name": "List orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders?take=25&skip=0",
              "host": ["{{base_url}}"], "path": ["orders"],
              "query": [
                { "key": "take", "value": "25" },
                { "key": "skip", "value": "0" },
                { "key": "status", "value": "paid", "disabled": true }
              ]
            }
          }
        },
        { "name": "Get order", "request": { "method": "GET", "url": "{{base_url}}/orders/<order-id>" } },
        {
          "name": "Fulfill order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/orders/gid://shopify/Order/12345/fulfill",
            "body": { "mode": "raw", "raw": "{\n  \"lineItems\": [{ \"id\": \"gid://shopify/LineItem/1\", \"quantity\": 1 }],\n  \"tracking\": { \"company\": \"DHL\", \"number\": \"TR123\", \"url\": \"https://track.dhl/TR123\" }\n}" }
          }
        },
        {
          "name": "Refund order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/orders/gid://shopify/Order/12345/refund",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 10.0,\n  \"currencyCode\": \"USD\",\n  \"note\": \"Customer request\"\n}" }
          }
        }
      ]
    },
    {
      "name": "7. Customers",
      "item": [
        {
          "name": "List customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/customers?take=25",
              "host": ["{{base_url}}"], "path": ["customers"],
              "query": [
                { "key": "take", "value": "25" },
                { "key": "q", "value": "", "disabled": true }
              ]
            }
          }
        },
        { "name": "Get customer", "request": { "method": "GET", "url": "{{base_url}}/customers/<customer-id>" } },
        {
          "name": "Set tags",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/customers/<customer-id>/tags",
            "body": { "mode": "raw", "raw": "{\n  \"tags\": [\"vip\", \"newsletter\"]\n}" }
          }
        },
        { "name": "List segments", "request": { "method": "GET", "url": "{{base_url}}/customers/segments/list" } },
        {
          "name": "Create segment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/customers/segments",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"VIP\",\n  \"rules\": { \"totalSpent\": { \"gt\": 1000 }, \"tags\": [\"vip\"] }\n}" }
          }
        }
      ]
    },
    {
      "name": "8. Purchase Orders",
      "item": [
        {
          "name": "List POs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/purchase-orders",
              "host": ["{{base_url}}"], "path": ["purchase-orders"],
              "query": [{ "key": "status", "value": "APPROVED", "disabled": true }]
            }
          }
        },
        { "name": "Get PO", "request": { "method": "GET", "url": "{{base_url}}/purchase-orders/<po-id>" } },
        {
          "name": "Create PO",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/purchase-orders",
            "body": { "mode": "raw", "raw": "{\n  \"vendorId\": \"<vendor-id>\",\n  \"locationId\": \"<location-id>\",\n  \"expectedAt\": \"2026-07-15\",\n  \"notes\": \"Q3 restock\",\n  \"tax\": 0,\n  \"shipping\": 25,\n  \"items\": [\n    { \"variantId\": \"<variant-id>\", \"sku\": \"SKU-001\", \"title\": \"Widget A\", \"qty\": 100, \"unitCost\": 5.00 },\n    { \"variantId\": \"<variant-id>\", \"sku\": \"SKU-002\", \"title\": \"Widget B\", \"qty\": 50, \"unitCost\": 8.00 }\n  ]\n}" }
          }
        },
        { "name": "Submit PO", "request": { "method": "PATCH", "url": "{{base_url}}/purchase-orders/<po-id>/submit" } },
        { "name": "Approve PO", "request": { "method": "PATCH", "url": "{{base_url}}/purchase-orders/<po-id>/approve" } },
        { "name": "Cancel PO", "request": { "method": "PATCH", "url": "{{base_url}}/purchase-orders/<po-id>/cancel" } },
        {
          "name": "Receive PO (full or partial)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/purchase-orders/<po-id>/receive",
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Partial shipment 1 of 2\",\n  \"items\": [\n    { \"poItemId\": \"<po-item-id>\", \"quantity\": 50, \"condition\": \"good\" },\n    { \"poItemId\": \"<po-item-id-2>\", \"quantity\": 25, \"condition\": \"good\" }\n  ]\n}" }
          }
        }
      ]
    },
    {
      "name": "9. Vendors",
      "item": [
        { "name": "List vendors", "request": { "method": "GET", "url": "{{base_url}}/vendors" } },
        { "name": "Get vendor", "request": { "method": "GET", "url": "{{base_url}}/vendors/<vendor-id>" } },
        {
          "name": "Create vendor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/vendors",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Distributors\",\n  \"contactName\": \"John Doe\",\n  \"email\": \"john@acme.com\",\n  \"phone\": \"+1-555-0100\",\n  \"address\": { \"line1\": \"1 Main St\", \"city\": \"NYC\", \"country\": \"US\" },\n  \"taxNumber\": \"VAT-12345\",\n  \"paymentTerms\": \"NET-30\"\n}" }
          }
        },
        {
          "name": "Update vendor",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/vendors/<vendor-id>",
            "body": { "mode": "raw", "raw": "{\n  \"paymentTerms\": \"NET-45\"\n}" }
          }
        },
        { "name": "Deactivate vendor", "request": { "method": "DELETE", "url": "{{base_url}}/vendors/<vendor-id>" } }
      ]
    },
    {
      "name": "10. Goods Receipts",
      "item": [
        { "name": "List receipts", "request": { "method": "GET", "url": "{{base_url}}/goods-receipts" } },
        { "name": "Get receipt", "request": { "method": "GET", "url": "{{base_url}}/goods-receipts/<gr-id>" } }
      ]
    },
    {
      "name": "11. CMS",
      "item": [
        {
          "name": "List blocks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/cms",
              "host": ["{{base_url}}"], "path": ["cms"],
              "query": [{ "key": "type", "value": "HERO_BANNER", "disabled": true }]
            }
          }
        },
        { "name": "Get block", "request": { "method": "GET", "url": "{{base_url}}/cms/<block-id>" } },
        {
          "name": "Upsert block",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/cms",
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"HERO_BANNER\",\n  \"handle\": \"home-hero\",\n  \"data\": {\n    \"title\": \"Summer Sale\",\n    \"subtitle\": \"Up to 50% off\",\n    \"imageUrl\": \"https://cdn.shopify.com/...\",\n    \"ctaText\": \"Shop now\",\n    \"ctaUrl\": \"/collections/sale\"\n  }\n}" }
          }
        },
        { "name": "Publish block", "request": { "method": "PATCH", "url": "{{base_url}}/cms/<block-id>/publish" } }
      ]
    },
    {
      "name": "12. Media",
      "item": [
        {
          "name": "List media",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/media",
              "host": ["{{base_url}}"], "path": ["media"],
              "query": [{ "key": "folder", "value": "products", "disabled": true }]
            }
          }
        },
        {
          "name": "Staged upload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/media/staged-upload",
            "body": { "mode": "raw", "raw": "{\n  \"filename\": \"hero.png\",\n  \"mimeType\": \"image/png\"\n}" }
          }
        },
        {
          "name": "Register file (after upload to staged URL)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/media/register",
            "body": { "mode": "raw", "raw": "{\n  \"url\": \"https://cdn.shopify.com/staged-uploads/...\",\n  \"cdnKey\": \"products/hero-abc.png\",\n  \"mimeType\": \"image/png\",\n  \"sizeBytes\": 154233,\n  \"folder\": \"products\"\n}" }
          }
        }
      ]
    },
    {
      "name": "13. Reports",
      "item": [
        {
          "name": "Sales (ShopifyQL)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/sales?since=-30d&until=today",
              "host": ["{{base_url}}"], "path": ["reports", "sales"],
              "query": [
                { "key": "since", "value": "-30d" },
                { "key": "until", "value": "today" }
              ]
            }
          }
        },
        { "name": "Inventory by location", "request": { "method": "GET", "url": "{{base_url}}/reports/inventory" } },
        { "name": "Vendor spend", "request": { "method": "GET", "url": "{{base_url}}/reports/vendors" } }
      ]
    },
    {
      "name": "14. Settings",
      "item": [
        { "name": "List all settings", "request": { "method": "GET", "url": "{{base_url}}/settings" } },
        { "name": "Get setting", "request": { "method": "GET", "url": "{{base_url}}/settings/tax.default_rate" } },
        {
          "name": "Set setting",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/settings/tax.default_rate",
            "body": { "mode": "raw", "raw": "{\n  \"value\": 0.18\n}" }
          }
        }
      ]
    },
    {
      "name": "15. Audit Logs",
      "item": [
        {
          "name": "List audit logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/audit-logs?take=50",
              "host": ["{{base_url}}"], "path": ["audit-logs"],
              "query": [
                { "key": "take", "value": "50" },
                { "key": "skip", "value": "0" },
                { "key": "resource", "value": "PurchaseOrder", "disabled": true },
                { "key": "userId", "value": "", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "16. Webhooks (Shopify → API)",
      "description": "Shopify POSTs here. HMAC verified with SHOPIFY_API_SECRET. Topic in URL uses dash instead of slash (orders/create → orders-create).",
      "item": [
        {
          "name": "orders/create",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Hmac-Sha256", "value": "<computed>" },
              { "key": "X-Shopify-Topic", "value": "orders/create" },
              { "key": "X-Shopify-Shop-Domain", "value": "test-store-uzhiv0ib.myshopify.com" }
            ],
            "url": "{{base_url}}/webhooks/shopify/orders-create",
            "body": { "mode": "raw", "raw": "{ \"id\": 1001, \"name\": \"#1001\", \"financial_status\": \"paid\" }" }
          }
        },
        {
          "name": "products/update",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Hmac-Sha256", "value": "<computed>" },
              { "key": "X-Shopify-Topic", "value": "products/update" }
            ],
            "url": "{{base_url}}/webhooks/shopify/products-update",
            "body": { "mode": "raw", "raw": "{ \"id\": 555, \"title\": \"Updated\", \"status\": \"active\" }" }
          }
        },
        {
          "name": "customers/redact (GDPR)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Hmac-Sha256", "value": "<computed>" },
              { "key": "X-Shopify-Topic", "value": "customers/redact" }
            ],
            "url": "{{base_url}}/webhooks/shopify/customers-redact",
            "body": { "mode": "raw", "raw": "{ \"shop_id\": 1, \"customer\": { \"id\": 999, \"email\": \"x@y.com\" } }" }
          }
        }
      ]
    }
  ]
}
